# Copy to `.env.local` for local dev, and set the same vars in Vercel for production.
# NEVER put real secrets in THIS file — it is committed to git. Real values go in .env.local.

# --- Auth.js (NextAuth v5) ---
# Generate a secret with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth client (see docs/admin-setup.md)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Only this Google account email may sign in to /admin
ALLOWED_EMAIL=arielefraim5@gmail.com

# Set to 1 in local dev to bypass Google login (NEVER takes effect in production)
# ADMIN_DEV_BYPASS=1

# --- GitHub content persistence ---
# Fine-grained PAT, single repo, Contents: Read and write.
# Leave GITHUB_TOKEN EMPTY in local dev to use the local-file fallback
# (PUT writes data/content.json to disk instead of committing).
GITHUB_TOKEN=
GITHUB_REPO=IdoLevi235/ArielPortfolio
GITHUB_BRANCH=main

# --- Cloudinary media uploads ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Same cloud name, exposed to the browser for the direct upload:
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
